.git
.gitignore
.gitattributes

# Editors / OS
.vscode
.idea
.DS_Store

# Docker / deploy tooling (not needed inside the image)
docker-compose*.yml
Dockerfile
.dockerignore
deploy-*.sh
check-status.sh

# Logs & misc
*.log
logs
ngrok-code.txt
README.md
